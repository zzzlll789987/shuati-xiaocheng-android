.screen {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 36rpx 36rpx 64rpx;
  background: #ffffff;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.progress {
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 700;
}

.home-button {
  height: 64rpx;
  margin: 0;
  padding: 0 22rpx;
  color: #f97316;
  background: #ffffff;
  border: 1rpx solid #fed7aa;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 64rpx;
}

.badge {
  display: inline-block;
  padding: 12rpx 20rpx;
  color: #f97316;
  background: #fff7ed;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.stem {
  margin: 32rpx 0 28rpx;
  color: #111827;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.3;
}

.choice {
  width: 100%;
  min-height: 96rpx;
  margin: 16rpx 0 0;
  padding: 18rpx 24rpx;
  color: #111827;
  background: #f3f4f6;
  border-radius: 8rpx;
  font-size: 32rpx;
  line-height: 1.35;
  text-align: left;
}

.correct {
  color: #166534;
  background: #dcfce7;
}

.wrong {
  color: #991b1b;
  background: #fee2e2;
}

.result {
  margin-top: 36rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 800;
}

.ok {
  color: #16a34a;
}

.bad {
  color: #dc2626;
}

.answer {
  margin-top: 18rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.explanation {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 30rpx;
  line-height: 1.5;
}

.primary {
  width: 100%;
  height: 96rpx;
  margin: 34rpx 0 0;
  color: #ffffff;
  background: #f97316;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 96rpx;
}
